# Local development — copy to .env and adjust as needed.
# With Docker Compose: run `docker compose up` then use localhost below.

MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=youthstore
MYSQL_PORT=3307
APP_PORT=3000

DATABASE_URL=mysql://root@localhost:3307/youthstore
JWT_SECRET=change-me-in-production
ADMIN_EMAIL=admin@malikatabayat.local
ADMIN_PASSWORD=admin123

# Optional persistent image directory. Production defaults to
# $HOME/.malikat-abayat/uploads/p when this is not set.
# UPLOAD_STORAGE_DIR=/absolute/path/to/uploads/p

# Olivraison Partners API (server-side only)
OLIVRAISON_API_KEY=
OLIVRAISON_SECRET_KEY=
OLIVRAISON_BASE_URL=https://partners.olivraison.com

# Optional: run `npm run build` without a database (migrations/seed skipped)
# DATABASE_URL=

# Optional seed controls (used by scripts/deploy-db.cjs during build)
# FORCE_SEED=1
# SKIP_SEED=1
