# Copy to .env on the VPS before deploying:
#   cp .env.production.example .env
#   nano .env

MYSQL_ROOT_PASSWORD=change-me-strong-db-password
MYSQL_DATABASE=youthstore

JWT_SECRET=change-me-long-random-secret-min-32-chars
ADMIN_EMAIL=admin@malikatabayat.com
ADMIN_PASSWORD=change-me-strong-admin-password

# Required on Hostinger so product photos survive redeploys.
# Example: /home/u299601727/.malikat-abayat/uploads/p
UPLOAD_STORAGE_DIR=/home/ACCOUNT/.malikat-abayat/uploads/p

# Olivraison Partners API (never expose these to browser code)
OLIVRAISON_API_KEY=api-change-me
OLIVRAISON_SECRET_KEY=change-me
OLIVRAISON_BASE_URL=https://partners.olivraison.com

# Meta Pixel (storefront only)
NEXT_PUBLIC_META_PIXEL_ID=1348553670819805

# Meta Conversions API (server-side only — generate in Meta Events Manager)
META_CAPI_ACCESS_TOKEN=
# Remove or leave empty in production after Test Events validation
# META_CAPI_TEST_EVENT_CODE=

# Optional: set FORCE_SEED=1 when running the seed profile to reset catalog
# FORCE_SEED=0
